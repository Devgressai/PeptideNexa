# ─── Rate limiting / cache (Upstash) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Search (Meilisearch) ─────────────────────────────────────────────────────
MEILI_HOST=""
