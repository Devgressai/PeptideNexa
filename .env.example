# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="PeptideNexa"

# ─── Supabase (Postgres + Auth + Storage) ─────────────────────────────────────
# Project settings → Database → Connection string.
#
# DATABASE_URL uses the pooled (pgBouncer) connection string on port 6543.
# Prisma requires `?pgbouncer=true&connection_limit=1` at the end of the URL
# when pointed at the pooler.
#
# DIRECT_URL uses the direct connection on port 5432 and is only used by
# `prisma migrate` and other schema operations.
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres"

# Project settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://<project>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role key — server only, NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="PeptideNexa <hello@peptidenexa.com>"
EMAIL_LEAD_INBOX="leads@peptidenexa.com"

# ─── On-demand revalidation (called by admin publish workflow) ────────────────
REVALIDATE_TOKEN=""

# ─── Rate limiting / cache (Upstash) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Search (Meilisearch) ─────────────────────────────────────────────────────
MEILI_HOST=""
MEILI_API_KEY=""

# ─── Analytics / Monitoring ───────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
SENTRY_DSN=""
